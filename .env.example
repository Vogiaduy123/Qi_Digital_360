# Copy this file to .env for local development
# Do NOT commit .env to git

# Persistent upload directory (absolute path on server is recommended)
# Render with disk mounted: /var/data/uploads
# Render without disk: leave empty to auto-fallback to local uploads/tmp
UPLOAD_DIR=

# Mail provider for production: resend | brevo | sendgrid | smtp
# If MAIL_PROVIDER is not set, SMTP flow is used.
MAIL_PROVIDER=resend
MAIL_FROM="Virtual Tour <onboarding@resend.dev>"

# API keys for HTTPS mail providers (set only the one you use)
RESEND_API_KEY=
BREVO_API_KEY=
SENDGRID_API_KEY=

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_SECURE=false

# Supabase Configuration
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-supabase-service-role-key

# JWT Token Configuration
JWT_SECRET=your-super-secret-key-change-this
